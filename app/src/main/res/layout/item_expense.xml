<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvExpenseType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_card_primary" />

                <TextView
                    android:id="@+id/tvExpenseDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_card_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvExpenseAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#EF4444"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/ivExpenseThumbnail"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:backgroundTint="@color/divider"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/text_on_card_secondary"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tvNoPhoto"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Description goes here..."
            android:textSize="14sp"
            android:textColor="@color/text_on_card_secondary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditExpense"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Edit"
                android:textSize="12sp"
                android:textColor="@color/emerald_500"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="@color/emerald_500"
                app:iconSize="16dp"
                android:padding="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteExpense"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Delete"
                android:textSize="12sp"
                android:textColor="@color/red_500"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="@color/red_500"
                app:iconSize="16dp"
                android:padding="0dp" />

        </LinearLayout>

        <!-- Hidden but needed for ID compatibility if used in adapter -->
        <TextView android:id="@+id/tvFullDescription" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
