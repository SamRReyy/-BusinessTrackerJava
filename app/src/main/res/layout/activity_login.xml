<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="600dp"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Card wrapper -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Logo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingBottom="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/app_logo"
                        android:contentDescription="App Logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Business Tracker"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_card_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Track your business expenses and budgets"
                        android:textSize="13sp"
                        android:textColor="@color/text_on_card_secondary" />
                </LinearLayout>

                <!-- LOGIN LAYOUT -->
                <LinearLayout
                    android:id="@+id/layoutLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="demo@businesstracker.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:passwordToggleEnabled="true"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter your password"
                            android:inputType="textPassword"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Sign In"
                        android:backgroundTint="#10b981"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tvGoToSignUp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:text="Don't have an account? Sign Up"
                        android:textColor="@color/emerald_500"
                        android:clickable="true"
                        android:focusable="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/divider" />

                    <Button
                        android:id="@+id/btnGoogle"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Sign in with Google"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/text_on_card_primary"
                        android:textAllCaps="false"
                        app:strokeColor="@color/divider"
                        app:icon="@drawable/ic_google"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconSize="24dp"
                        app:iconTint="@null" />

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:text="Forgot password?"
                        android:textColor="#10b981"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- SIGN UP LAYOUT -->
                <LinearLayout
                    android:id="@+id/layoutSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSignUpName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="John Doe"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSignUpEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="example@email.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:passwordToggleEnabled="true"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSignUpPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Create a password"
                            android:inputType="textPassword"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Create Account"
                        android:backgroundTint="#10b981"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btnBackToSignInFromSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Already have an account? Sign In"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/emerald_500" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/divider" />

                    <Button
                        android:id="@+id/btnGoogleSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Sign up with Google"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/text_on_card_primary"
                        android:textAllCaps="false"
                        app:strokeColor="@color/divider"
                        app:icon="@drawable/ic_google"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconSize="24dp"
                        app:iconTint="@null" />
                </LinearLayout>

                <!-- RESET PASSWORD LAYOUT -->
                <LinearLayout
                    android:id="@+id/layoutReset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etResetEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter your email"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnSendReset"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Send Reset Email"
                        android:backgroundTint="#10b981"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btnBackToSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Back to Sign In"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/emerald_500" />
                </LinearLayout>

                <!-- VERIFY CODE LAYOUT -->
                <LinearLayout
                    android:id="@+id/layoutVerifyCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verification Code"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_card_primary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintTextColor="@color/emerald_500"
                        app:boxStrokeColor="@color/emerald_500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVerifyCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter 6-digit code"
                            android:inputType="number"
                            android:maxLength="6"
                            android:textColor="@color/text_on_card_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnVerifyCode"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Verify Code"
                        android:backgroundTint="#10b981"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btnBackToReset"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Back to Reset"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/emerald_500" />
                </LinearLayout>

                <!-- reCAPTCHA Logo and Disclosure -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="reCAPTCHA"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#4285F4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" v3"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This app is protected by reCAPTCHA"
                        android:textSize="10sp"
                        android:textColor="@color/text_on_card_secondary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google "
                            android:textSize="10sp"
                            android:textColor="@color/text_on_card_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy Policy"
                            android:textSize="10sp"
                            android:textColor="@color/emerald_500" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" &amp; "
                            android:textSize="10sp"
                            android:textColor="@color/text_on_card_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terms"
                            android:textSize="10sp"
                            android:textColor="@color/emerald_500" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
